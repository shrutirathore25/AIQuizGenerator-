@model List<QuizQuestion>
@{
    ViewData["Title"] = "Take the Paper";
}

<div class="quiz-header">
    <span class="eyebrow">In Progress</span>
    <h2 style="font-family:'Literata',serif; font-size:1.6rem;">Answer every question</h2>
    <div class="quiz-meta">
        <span class="timer" id="timer">00:00</span>
    </div>
    <div class="progress-bar"><div class="progress-fill" id="progress"></div></div>
    <p id="progressText">0 / @Model.Count answered</p>
    <p class="kbd-hint">Tip: press 1–4 to pick an answer, ↑ / ↓ to move between questions</p>
</div>

<form method="post" action="/Quiz/Submit" id="quizForm">
    <input type="hidden" name="elapsedSeconds" id="elapsedSeconds" value="0" />
    @for (int i = 0; i < Model.Count; i++)
    {
        var q = Model[i];
        <div class="question-card" id="qcard-@q.Number" data-qnum="@q.Number">
            <button type="button" class="flag-btn" data-flag-for="@q.Number">Flag</button>
            <h3>Q@(q.Number). @q.Question</h3>
            <div class="options">
                @for (int j = 0; j < q.Options.Count; j++)
                {
                    <label class="option">
                        <input type="radio" name="answers[q@(q.Number)]" value="@j" onchange="updateProgress()" />
                        <span class="option-letter">@((char)('A' + j))</span>
                        @q.Options[j]
                    </label>
                }
            </div>
        </div>
    }

    <button type="submit" class="btn btn-primary">Hand In Paper</button>
</form>

@section Scripts {
<script>
    function updateProgress() {
        const total = @Model.Count;
        const answered = document.querySelectorAll('input[type=radio]:checked').length;
        document.getElementById('progressText').textContent = answered + ' / ' + total + ' answered';
        document.getElementById('progress').style.width = (answered / total * 100) + '%';
    }

    // Timer
    let seconds = 0;
    const timerEl = document.getElementById('timer');
    const elapsedField = document.getElementById('elapsedSeconds');
    setInterval(() => {
        seconds++;
        const m = Math.floor(seconds / 60).toString().padStart(2, '0');
        const s = (seconds % 60).toString().padStart(2, '0');
        timerEl.textContent = m + ':' + s;
        elapsedField.value = seconds;
    }, 1000);

    // Flag for review
    document.querySelectorAll('.flag-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const card = document.getElementById('qcard-' + btn.dataset.flagFor);
            const active = card.classList.toggle('flagged');
            btn.classList.toggle('active', active);
            btn.textContent = active ? 'Flagged' : 'Flag';
        });
    });

    // Keyboard shortcuts: 1-4 to answer current question, arrows to move focus
    const cards = Array.from(document.querySelectorAll('.question-card'));
    let currentIndex = 0;

    function scrollToCard(idx) {
        if (idx < 0 || idx >= cards.length) return;
        currentIndex = idx;
        cards[idx].scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    document.addEventListener('keydown', (e) => {
        if (['1', '2', '3', '4'].includes(e.key)) {
            const card = cards[currentIndex];
            if (!card) return;
            const options = card.querySelectorAll('input[type=radio]');
            const opt = options[parseInt(e.key, 10) - 1];
            if (opt) { opt.checked = true; updateProgress(); }
        } else if (e.key === 'ArrowDown') {
            e.preventDefault();
            scrollToCard(currentIndex + 1);
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            scrollToCard(currentIndex - 1);
        }
    });
</script>
}
